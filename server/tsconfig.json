{
  "compilerOptions": {
    "module": "nodenext",
    "target": "ES2021",
    "moduleResolution": "nodenext",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
  "include": ["src/**/*", "test/**/*"]
}
